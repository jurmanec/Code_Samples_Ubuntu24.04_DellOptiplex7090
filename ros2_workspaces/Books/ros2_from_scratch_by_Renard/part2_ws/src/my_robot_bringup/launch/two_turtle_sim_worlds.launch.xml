<launch>
    <node pkg="turtlesim" exec="turtlesim_node" namespace="/world1">
        <param from="$(find-pkg-share my_robot_bringup)/config/two_turtle_sim_worlds.yaml" />
    </node>
    <node pkg="turtlesim" exec="turtlesim_node" namespace="/world2">
        <param from="$(find-pkg-share my_robot_bringup)/config/two_turtle_sim_worlds.yaml" />
    </node>
    <node pkg="turtle_controller" exec="turtle1_controller_ch8_param_challenge" namespace="/world1">
        <remap from="/turtle1/pose" to="/world1/turtle1/pose" />
        <remap from="/turtle1/cmd_vel" to="/world1/turtle1/cmd_vel" />
        <remap from="/turtle1/set_pen" to="/world1/turtle1/set_pen" />
        <param from="$(find-pkg-share my_robot_bringup)/config/two_turtle_sim_worlds.yaml" />
    </node>
    <node pkg="turtle_controller" exec="turtle1_controller_ch8_param_challenge" namespace="/world2">
        <remap from="/turtle1/pose" to="/world2/turtle1/pose" />
        <remap from="/turtle1/cmd_vel" to="/world2/turtle1/cmd_vel" />
        <remap from="/turtle1/set_pen" to="/world2/turtle1/set_pen" />
        <param from="$(find-pkg-share my_robot_bringup)/config/two_turtle_sim_worlds.yaml" />
    </node>
</launch>